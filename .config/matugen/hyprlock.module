# ~/.config/matugen/hyprlock.module
$primary = rgb({{colors.primary.default.hex}})
$on_primary = rgb({{colors.on_primary.default.hex}})
$secondary = rgb({{colors.secondary.default.hex}})
$on_secondary = rgb({{colors.on_secondary.default.hex}})
$surface = rgb({{colors.surface.default.hex}})
$on_surface = rgb({{colors.on_surface.default.hex}})
$surface_variant = rgb({{colors.surface_variant.default.hex}})
$on_surface_variant = rgb({{colors.on_surface_variant.default.hex}})
$error = rgb({{colors.error.default.hex}})
$on_error = rgb({{colors.on_error.default.hex}})
$outline = rgb({{colors.outline.default.hex}})
